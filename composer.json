{
    "name": "wezlo/wezlo-tabs-persistentes",
    "description": "Browser-like workspace tabs for Filament panels",
    "keywords": ["laravel", "filament", "tabs", "workspace", "browser-tabs"],
    "license": "MIT",
    "version": "1.0.0",
    "type": "library",
    "require": {
        "php": "^8.2",
        "filament/filament": "^4.0 || ^5.0",
        "spatie/laravel-package-tools": "^1.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0 || ^10.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-livewire": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Wezlo\\TabsPersistentes\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Wezlo\\TabsPersistentes\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Wezlo\\FilamentWorkspaceTabs\\WorkspaceTabsServiceProvider"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
